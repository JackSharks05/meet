# Serves the admin SPA and proxies /api to the admin Go listener, same-origin.
# Sessions/cookies work without CORS because the page and the API share an origin.
:80 {
	encode gzip

	# API → admin Go listener (internal docker network). Path is preserved.
	handle /api/* {
		reverse_proxy server-admin:3002
	}

	# Everything else → the SPA, with client-side-routing fallback to index.html.
	handle {
		root * /srv
		try_files {path} /index.html
		file_server
	}
}
